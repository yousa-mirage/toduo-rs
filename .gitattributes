# Git attributes for todo-app workspace

# Set default line ending behavior
* text=auto eol=lf

# Ensure shell scripts and CI configs use LF
*.sh text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Mark binary files
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.png binary
*.ico binary
*.icns binary

# Normalize Vue and Rust files
*.vue text
*.rs text
*.toml text
